intent CreateInvoice

id: INT_CREATE_INV_001
desc:
  Creates invoice for an approved order.

sla: 500ms
criticality: high
owner: billing-team

input:
  order_id: s
  customer: @Entity.Customer

validate:
  @Rule.Eligible

process:
  new invoice @Entity.Invoice
  set invoice.customer_id customer.customer_id
  set invoice.status "STS_INVOICE_001.Draft"
  save invoice

emit:
  @Event.InvoiceCreated

fail:
  @Error.CustomerNotFound
  @Error.InsufficientBalance

return: @Entity.Invoice

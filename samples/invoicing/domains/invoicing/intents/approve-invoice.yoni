intent ApproveInvoice

id: INT_APPROVE_INV_001
desc:
  Approves draft invoice for sending.

input:
  invoice: @Entity.Invoice

validate:
  @Rule.InvoiceAmountPositive

process:
  set invoice.status "STS_INVOICE_001.Pending"
  save invoice

emit:
  @Event.InvoiceApproved

fail:
  @Error.InvoiceNotFound
  @Error.InvalidStateTransition

return: @Entity.Invoice

